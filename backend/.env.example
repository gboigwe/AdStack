# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/adstack_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=adstack_db
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Stacks Blockchain
STACKS_NETWORK=testnet
STACKS_API_URL=https://stacks-node-api.testnet.stacks.co
STACKS_SENDER_KEY=
STACKS_SENDER_ADDRESS=
CONTRACT_SUBSCRIPTION_MANAGER=
CONTRACT_RECURRING_PAYMENT=
CONTRACT_SUBSCRIPTION_BENEFITS=
DEPLOYER_MNEMONIC=
DEPLOYER_WALLET_INDEX=0

# Authentication
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRATION=7d

# Email
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=
EMAIL_FROM=noreply@adstack.io
EMAIL_FROM_NAME=AdStack
# SMTP (optional, used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_MAX_RETRIES=3
PAYMENT_RETRY_DELAY=86400
GRACE_PERIOD_DAYS=7

# Rate Limiting
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_BASIC_TIER=1000
RATE_LIMIT_PRO_TIER=10000
RATE_LIMIT_ENTERPRISE_TIER=100000
RATE_LIMIT_WINDOW=3600

# Subscription
DEFAULT_TIER=free
ENABLE_PRORATION=true
PRORATION_BEHAVIOR=create_prorations
CANCEL_AT_PERIOD_END_DEFAULT=false
REQUIRE_CANCELLATION_REASON=true

# Usage Tracking
USAGE_SYNC_INTERVAL=3600
USAGE_ALERT_THRESHOLD_1=75
USAGE_ALERT_THRESHOLD_2=90
USAGE_ALERT_THRESHOLD_3=100

# Cache
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
# SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=mixpanel
# ANALYTICS_TOKEN=

# Webhooks
WEBHOOK_SECRET=change-this-webhook-secret
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=10000

# Security
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
API_KEY_HEADER=X-API-Key
API_KEY_REQUIRED=false
SESSION_SECRET=change-this-session-secret
SESSION_MAX_AGE=86400000

# Integrations
KYC_PROVIDER=onfido
# KYC_API_KEY=
IPFS_GATEWAY=https://ipfs.io
IPFS_API_URL=https://api.pinata.cloud

# Feature Flags
FEATURE_SUBSCRIPTION_ENABLED=true
FEATURE_USAGE_TRACKING_ENABLED=true
FEATURE_INVOICING_ENABLED=true
FEATURE_PAYMENT_RETRY_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=true

# Development
DEBUG=false
ENABLE_API_DOCS=true
ENABLE_SEED_DATA=false
MOCK_PAYMENT_PROCESSOR=true
MOCK_EMAIL_SERVICE=true
MOCK_BLOCKCHAIN=true
