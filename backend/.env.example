NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://adstack:adstack_dev@localhost:5432/adstack
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Stacks Blockchain
STACKS_NETWORK=devnet
STACKS_API_URL=http://localhost:3999
STACKS_DEPLOYER_KEY=
CONTRACT_ADDRESS=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Authentication
JWT_SECRET=change-this-in-production
JWT_EXPIRY=24h

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@adstack.io

# Alerting
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
